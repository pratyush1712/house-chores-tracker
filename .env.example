# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# ── SMTP ────────────────────────────────────────────────────────────────────────
# Gmail (default if you omit SMTP_HOST):
#   SMTP_HOST=smtp.gmail.com  SMTP_PORT=465  (leave SMTP_USE_STARTTLS unset)
#   SMTP_USERNAME=you@gmail.com
#   SMTP_PASSWORD=<16-char App Password>  https://myaccount.google.com/apppasswords
#
# Google Workspace custom domain (same as Gmail SMTP):
#   SMTP_USERNAME=you@yourdomain.com
#   SMTP_FROM_EMAIL=you@yourdomain.com   # optional; defaults to SMTP_USERNAME
#
# Namecheap Private Email:
#   SMTP_HOST=mail.privateemail.com
#   SMTP_PORT_SSL=465
#   SMTP_PORT_TLS=587   # optional reference; if both SSL+TLS lines exist, app uses 465+SSL
#
SMTP_HOST=smtp.gmail.com
# Option A - single port:
SMTP_PORT=465
# SMTP_PORT=587
# SMTP_USE_STARTTLS=true
#
# Option B - Private Email / Namecheap style (both set → uses SSL port):
# SMTP_PORT_SSL=465
# SMTP_PORT_TLS=587

SMTP_USERNAME=you@example.com
SMTP_PASSWORD=
# SMTP_FROM_EMAIL=chores@yourdomain.com

# ── Upstash Redis ─────────────────────────────────────────────────────────────
# upstash-redis reads these two specific names via Redis.from_env().
#
# On Vercel: add these as extra environment variables in project Settings,
# using Vercel's reference syntax to pull from the KV integration values:
#   UPSTASH_REDIS_REST_URL   = ${KV_REST_API_URL}
#   UPSTASH_REDIS_REST_TOKEN = ${KV_REST_API_TOKEN}
#
# Locally: paste the actual values from your Upstash console or Vercel KV tab.
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_read_write_token

# These are injected by Vercel KV automatically - listed here for reference
# only. Do NOT use them directly in code; use the UPSTASH_* names above.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# KV_REST_API_READ_ONLY_TOKEN=
# KV_URL=
# REDIS_URL=
