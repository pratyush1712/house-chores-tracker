# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# ── Gmail SMTP ────────────────────────────────────────────────────────────────
# Use a Gmail App Password (not your account password).
# Generate one at: https://myaccount.google.com/apppasswords
SMTP_USERNAME=your_gmail@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Upstash Redis ─────────────────────────────────────────────────────────────
# upstash-redis reads these two specific names via Redis.from_env().
#
# On Vercel: add these as extra environment variables in project Settings,
# using Vercel's reference syntax to pull from the KV integration values:
#   UPSTASH_REDIS_REST_URL   = ${KV_REST_API_URL}
#   UPSTASH_REDIS_REST_TOKEN = ${KV_REST_API_TOKEN}
#
# Locally: paste the actual values from your Upstash console or Vercel KV tab.
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_read_write_token

# These are injected by Vercel KV automatically — listed here for reference
# only. Do NOT use them directly in code; use the UPSTASH_* names above.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# KV_REST_API_READ_ONLY_TOKEN=
# KV_URL=
# REDIS_URL=
